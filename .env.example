# SEO-AGI Configuration
# Copy to ~/.config/seo-agi/.env and fill in your keys
#
# mkdir -p ~/.config/seo-agi
# cp .env.example ~/.config/seo-agi/.env

# DataForSEO (required for live SERP research)
# Sign up at https://dataforseo.com -- ~$0.002 per query
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Search Console (optional -- for owned site performance data)
# Create a service account at https://console.cloud.google.com
# Grant it read access to your GSC property
GSC_SERVICE_ACCOUNT_PATH=

# Ahrefs API key (optional -- skill also works via Ahrefs MCP)
AHREFS_API_KEY=

# SEMRush API key (optional -- skill also works via SEMRush MCP)
SEMRUSH_API_KEY=
